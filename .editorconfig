root = true

[*]
charset = utf-8
end_of_line = lf
indent_style = space
indent_size = 4
insert_final_newline = true
trim_trailing_whitespace = true

[*.{md,yml,yaml,json}]
indent_size = 2

[*.{csproj,props,targets,sln}]
indent_size = 2

[*.cs]
# Modern C# preferences
csharp_style_var_for_built_in_types = false:warning
csharp_style_var_when_type_is_apparent = true:suggestion
csharp_style_var_elsewhere = false:suggestion
csharp_prefer_simple_using_statement = true:suggestion
csharp_style_namespace_declarations = file_scoped:warning
csharp_style_prefer_primary_constructors = true:suggestion
csharp_style_prefer_method_group_conversion = true:suggestion
csharp_style_expression_bodied_methods = when_on_single_line:suggestion
csharp_style_expression_bodied_properties = true:suggestion

# Sort usings
dotnet_sort_system_directives_first = true
dotnet_separate_import_directive_groups = false

# Nullable annotations are mandatory
dotnet_diagnostic.CS8600.severity = error
dotnet_diagnostic.CS8602.severity = error
dotnet_diagnostic.CS8603.severity = error
dotnet_diagnostic.CS8618.severity = error
dotnet_diagnostic.CS8625.severity = error

# Public APIs must be documented (loosen if too noisy)
dotnet_diagnostic.CS1591.severity = suggestion

# Code analysis
dotnet_diagnostic.CA1062.severity = warning  # Validate public args
dotnet_diagnostic.CA1822.severity = suggestion  # Mark as static

# Naming
dotnet_naming_rule.interface_should_be_begins_with_i.severity = error
dotnet_naming_rule.interface_should_be_begins_with_i.symbols = interface
dotnet_naming_rule.interface_should_be_begins_with_i.style = begins_with_i
dotnet_naming_symbols.interface.applicable_kinds = interface
dotnet_naming_style.begins_with_i.required_prefix = I
dotnet_naming_style.begins_with_i.capitalization = pascal_case

# EF Core migrations are partially auto-generated and don't need strict style enforcement.
[**/Migrations/**.cs]
dotnet_diagnostic.IDE0008.severity = none
dotnet_diagnostic.CA1062.severity = none
dotnet_diagnostic.CA1707.severity = none
dotnet_diagnostic.CS1591.severity = none
generated_code = true

# Tests use Method_Scenario_Outcome naming per architecture-notes.md;
# CA1707 is not appropriate for test method names.
[tests/**/*.cs]
dotnet_diagnostic.CA1707.severity = none
dotnet_diagnostic.CS1591.severity = none
